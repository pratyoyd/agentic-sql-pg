{"session_id": "task3_rep_a", "query_seq": 1, "timestamp": 1776126865.5504184, "raw_sql": "WITH company_film_counts AS (\n  SELECT \n    mc.company_id,\n    cn.name,\n    cn.country_code,\n    COUNT(DISTINCT mc.movie_id) AS film_count,\n    RANK() OVER (ORDER BY COUNT(DISTINCT mc.movie_id) DESC) AS rnk\n  FROM movie_companies mc\n  JOIN company_name cn ON cn.id = mc.company_id\n  JOIN title t ON t.id = mc.movie_id\n  WHERE mc.company_type_id = 2  -- production companies\n    AND t.kind_id = 1            -- movies only\n    AND t.production_year IS NOT NULL\n  GROUP BY mc.company_id, cn.name, cn.country_code\n)\nSELECT company_id, name, country_code, film_count, rnk\nFROM company_film_counts\nWHERE rnk > 10 AND film_count >= 20\nORDER BY film_count DESC\nLIMIT 30;", "tables": ["company_film_counts", "company_name", "movie_companies", "title"], "columns": ["company_id", "company_type_id", "country_code", "film_count", "id", "kind_id", "movie_id", "name", "production_year", "rnk"], "predicates": [], "group_by_cols": [], "result_rows": 30, "success": true, "error_msg": null, "execution_ms": 3477.67, "plan_tree": [{"node_id": 0, "operator_type": "Limit", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 30, "actual_card": 30, "operator_signature": "ee6fd3826ce329f56f4505bcf55b3c987a7844d6", "children_ids": [1], "alias": "", "relation_aliases": ["cn", "mc", "t"]}, {"node_id": 1, "operator_type": "Subquery Scan", "tables": [], "predicates": ["((company_film_counts.rnk > 10) AND (company_film_counts.film_count >= 20))"], "groupby_keys": [], "estimated_card": 38354, "actual_card": 30, "operator_signature": "0434783a757a91ee6eed2ef9d6483aa0bdcab2cf", "children_ids": [2], "alias": "company_film_counts", "relation_aliases": ["cn", "mc", "t"]}, {"node_id": 2, "operator_type": "WindowAgg", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 345182, "actual_card": 40, "operator_signature": "158889157894e28029215d5f4c6447297eb18934", "children_