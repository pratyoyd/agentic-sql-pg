{"session_id": "task3_rep_a", "query_seq": 5, "timestamp": 1776126929.9528608, "raw_sql": "WITH company_movies AS (\n  SELECT mc.company_id, mc.movie_id, t.production_year\n  FROM movie_companies mc\n  JOIN title t ON t.id = mc.movie_id\n  WHERE mc.company_id IN (8416, 17693, 15275)\n    AND mc.company_type_id = 2\n    AND t.kind_id = 1\n    AND t.production_year IS NOT NULL\n)\nSELECT \n  cn.name,\n  (cm.production_year / 10) * 10 AS decade,\n  COUNT(DISTINCT cm.movie_id) AS films\nFROM company_movies cm\nJOIN company_name cn ON cn.id = cm.company_id\nGROUP BY cn.name, decade\nORDER BY cn.name, decade;", "tables": ["company_movies", "company_name", "movie_companies", "title"], "columns": ["company_id", "company_type_id", "decade", "id", "kind_id", "movie_id", "name", "production_year"], "predicates": [], "group_by_cols": [], "result_rows": 12, "success": true, "error_msg": null, "execution_ms": 27.76, "plan_tree": [{"node_id": 0, "operator_type": "Aggregate", "tables": [], "predicates": [], "groupby_keys": ["cn.name", "(((t.production_year / 10) * 10))"], "estimated_card": 40, "actual_card": 12, "operator_signature": "4ede9b02e22a24f18977ba315494bc86327cfb09", "children_ids": [1], "alias": "", "relation_aliases": ["cn", "mc", "t"]}, {"node_id": 1, "operator_type": "Sort", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 40, "actual_card": 438, "operator_signature": "0d43b00b2bd74b2f9ad41224fae1824d4f0c92cc", "children_ids": [2], "alias": "", "relation_aliases": ["cn", "mc", "t"]}, {"node_id": 2, "operator_type": "Nested Loop", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 40, "actual_card": 438, "operator_signature": "8d41482b988b72be1aea13b7328bb139e8b9c9c2", "children_ids": [3, 6], "alias": "", "relation_aliases": ["cn", "mc", "t"]}, {"node_id": 3, "operator_type": "Nested Loop", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 40, "actual_card": 438, "operator_signature": "8d41482b988b72be1aea13b7