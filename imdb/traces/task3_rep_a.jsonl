{"session_id": "task3_rep_a", "query_seq": 7, "timestamp": 1776126953.3162727, "raw_sql": "WITH company_movies AS (\n  SELECT mc.company_id, mc.movie_id\n  FROM movie_companies mc\n  JOIN title t ON t.id = mc.movie_id\n  WHERE mc.company_id IN (8416, 17693, 15275)\n    AND mc.company_type_id = 2\n    AND t.kind_id = 1\n),\ntop_cast AS (\n  SELECT ci.movie_id, ci.person_id, ci.nr_order\n  FROM cast_info ci\n  WHERE ci.role_id IN (SELECT id FROM role_type WHERE role IN ('actor','actress'))\n    AND ci.nr_order <= 3\n    AND ci.movie_id IN (SELECT movie_id FROM company_movies)\n)\nSELECT \n  cn.name AS company,\n  n.name AS actor,\n  COUNT(DISTINCT tc.movie_id) AS appearances,\n  AVG(tc.nr_order) AS avg_billing\nFROM company_movies cm\nJOIN company_name cn ON cn.id = cm.company_id\nJOIN top_cast tc ON tc.movie_id = cm.movie_id\nJOIN name n ON n.id = tc.person_id\nGROUP BY cn.name, n.name\nHAVING COUNT(DISTINCT tc.movie_id) >= 3\nORDER BY cn.name, appearances DESC\nLIMIT 60;", "tables": ["cast_info", "company_movies", "company_name", "movie_companies", "name", "role_type", "title", "top_cast"], "columns": ["appearances", "company_id", "company_type_id", "id", "kind_id", "movie_id", "name", "nr_order", "person_id", "role", "role_id"], "predicates": [], "group_by_cols": [], "result_rows": 49, "success": true, "error_msg": null, "execution_ms": 936.13, "plan_tree": [{"node_id": 0, "operator_type": "Limit", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 2, "actual_card": 49, "operator_signature": "ee6fd3826ce329f56f4505bcf55b3c987a7844d6", "children_ids": [1, 4], "alias": "", "relation_aliases": ["ci", "cn", "mc", "n", "role_type", "t"]}, {"node_id": 1, "operator_type": "Nested Loop", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 42, "actual_card": 459, "operator_signature": "8d41482b988b72be1aea13b7328bb139e8b9c9c2", "children_ids": [2, 3], "alias": "", "relation_aliases": ["mc", "t"]}, {"node_id": 2, "operator_type": "Index S