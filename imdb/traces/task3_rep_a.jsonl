{"session_id": "task3_rep_a", "query_seq": 6, "timestamp": 1776126940.6080217, "raw_sql": "WITH company_movies AS (\n  SELECT mc.company_id, mc.movie_id\n  FROM movie_companies mc\n  JOIN title t ON t.id = mc.movie_id\n  WHERE mc.company_id IN (8416, 17693, 15275)\n    AND mc.company_type_id = 2\n    AND t.kind_id = 1\n),\nratings AS (\n  SELECT mii.movie_id, mii.info::numeric AS rating\n  FROM movie_info_idx mii\n  WHERE mii.info_type_id = (SELECT id FROM info_type WHERE info = 'rating')\n    AND mii.info ~ '^\\d+(\\.\\d+)?$'\n)\nSELECT \n  cn.name,\n  COUNT(DISTINCT cm.movie_id) AS total_films,\n  COUNT(DISTINCT r.movie_id) AS rated_films,\n  ROUND(AVG(r.rating), 2) AS avg_rating,\n  ROUND(MIN(r.rating), 2) AS min_rating,\n  ROUND(MAX(r.rating), 2) AS max_rating,\n  ROUND(PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY r.rating)::numeric, 2) AS median_rating\nFROM company_movies cm\nJOIN company_name cn ON cn.id = cm.company_id\nLEFT JOIN ratings r ON r.movie_id = cm.movie_id\nGROUP BY cn.name\nORDER BY avg_rating DESC;", "tables": ["company_movies", "company_name", "info_type", "movie_companies", "movie_info_idx", "ratings", "title"], "columns": ["avg_rating", "company_id", "company_type_id", "id", "info", "info_type_id", "kind_id", "movie_id", "name", "rating"], "predicates": [], "group_by_cols": [], "result_rows": 3, "success": true, "error_msg": null, "execution_ms": 76.61, "plan_tree": [{"node_id": 0, "operator_type": "Sort", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 42, "actual_card": 3, "operator_signature": "0d43b00b2bd74b2f9ad41224fae1824d4f0c92cc", "children_ids": [1, 2], "alias": "", "relation_aliases": ["cn", "info_type", "mc", "mii", "t"]}, {"node_id": 1, "operator_type": "Seq Scan", "tables": ["info_type"], "predicates": ["((info)::text = 'rating'::text)"], "groupby_keys": [], "estimated_card": 1, "actual_card": 1, "operator_signature": "eea304a47d302298a248e548523f5dc9d21bad87", "children_ids": [], "alias": "info_type", "rela