{"session_id": "task3_rep_a", "query_seq": 4, "timestamp": 1776126920.084528, "raw_sql": "WITH target_companies AS (\n  SELECT id AS company_id, name FROM company_name\n  WHERE id IN (8416, 17693, 15275)  -- Miramax, Nu Image, Millennium Films\n),\ncompany_movies AS (\n  SELECT mc.company_id, mc.movie_id\n  FROM movie_companies mc\n  WHERE mc.company_id IN (8416, 17693, 15275)\n    AND mc.company_type_id = 2\n),\ngenres AS (\n  SELECT mi.movie_id, mi.info AS genre\n  FROM movie_info mi\n  WHERE mi.info_type_id = (SELECT id FROM info_type WHERE info = 'genres')\n)\nSELECT \n  tc.name,\n  g.genre,\n  COUNT(DISTINCT cm.movie_id) AS film_count\nFROM target_companies tc\nJOIN company_movies cm ON cm.company_id = tc.company_id\nJOIN genres g ON g.movie_id = cm.movie_id\nGROUP BY tc.name, g.genre\nORDER BY tc.name, film_count DESC;", "tables": ["company_movies", "company_name", "genres", "info_type", "movie_companies", "movie_info", "target_companies"], "columns": ["company_id", "company_type_id", "film_count", "genre", "id", "info", "info_type_id", "movie_id", "name"], "predicates": [], "group_by_cols": [], "result_rows": 58, "success": true, "error_msg": null, "execution_ms": 133.14, "plan_tree": [{"node_id": 0, "operator_type": "Incremental Sort", "tables": [], "predicates": [], "groupby_keys": [], "estimated_card": 2, "actual_card": 58, "operator_signature": "7bf739c0792f4bd5ba3c1ac3e1a1c0b84db78ef9", "children_ids": [1, 2], "alias": "", "relation_aliases": ["company_name", "info_type", "mc", "mi"]}, {"node_id": 1, "operator_type": "Seq Scan", "tables": ["info_type"], "predicates": ["((info)::text = 'genres'::text)"], "groupby_keys": [], "estimated_card": 1, "actual_card": 1, "operator_signature": "eea304a47d302298a248e548523f5dc9d21bad87", "children_ids": [], "alias": "info_type", "relation_aliases": ["info_type"]}, {"node_id": 2, "operator_type": "Aggregate", "tables": [], "predicates": [], "groupby_keys": ["company_name.name", "mi.info"], "estimated_card": 1, "actua