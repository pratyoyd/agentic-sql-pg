{
  "query_seq": 6,
  "sql": "WITH dirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id = (SELECT id FROM role_type WHERE role = 'director')\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id IN (SELECT id FROM role_type WHERE role IN ('actor', 'actress'))\n),\nrated_movies AS (\n  SELECT DISTINCT movie_id\n  FROM movie_info_idx\n  WHERE info_type_id = (SELECT id FROM info_type WHERE info = 'votes')\n    AND info::integer >= 500\n),\ntop_director_ids AS (\n  SELECT id, name FROM name\n  WHERE name IN ('To, Johnnie', 'Miike, Takashi', 'Rodriguez, Robert')\n),\ntop_pairs AS (\n  SELECT d.director_id, a.actor_id, COUNT(DISTINCT d.movie_id) AS film_count,\n         array_agg(DISTINCT d.movie_id) AS movie_ids\n  FROM dirs d\n  JOIN acts a ON d.movie_id = a.movie_id AND d.director_id != a.actor_id\n  JOIN title t ON t.id = d.movie_id\n  JOIN rated_movies rm ON rm.movie_id = t.id\n  JOIN top_director_ids tdi ON tdi.id = d.director_id\n  WHERE t.production_year BETWEEN 1990 AND 2010\n    AND t.kind_id = 1\n  GROUP BY d.director_id, a.actor_id\n  HAVING COUNT(DISTINCT d.movie_id) >= 4\n),\ngenres AS (\n  SELECT tp.director_id, tp.actor_id, tp.film_count,\n         mi.info AS genre,\n         COUNT(*) AS genre_count\n  FROM top_pairs tp\n  JOIN movie_info mi ON mi.movie_id = ANY(tp.movie_ids)\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'genres')\n  GROUP BY tp.director_id, tp.actor_id, tp.film_count, mi.info\n)\nSELECT\n  nd.name AS director,\n  na.name AS actor,\n  g.film_count,\n  g.genre,\n  g.genre_count\nFROM genres g\nJOIN name nd ON nd.id = g.director_id\nJOIN name na ON na.id = g.actor_id\nWHERE g.genre_count >= 3\nORDER BY nd.name, g.genre_count DESC;",
