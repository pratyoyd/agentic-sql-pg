{
  "query_seq": 12,
  "sql": "WITH dirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id = (SELECT id FROM role_type WHERE role = 'director')\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id IN (SELECT id FROM role_type WHERE role IN ('actor', 'actress'))\n),\nrated_movies AS (\n  SELECT DISTINCT movie_id\n  FROM movie_info_idx\n  WHERE info_type_id = (SELECT id FROM info_type WHERE info = 'votes')\n    AND info::integer >= 500\n),\n-- Compare genre diversity: repeat pairs (>=4 films) vs one-off pairs (exactly 1 film)\ndir_ids AS (\n  SELECT id FROM name\n  WHERE name IN ('To, Johnnie','Marshall, Garry','Miike, Takashi',\n                 'Rodriguez, Robert','Egoyan, Atom','Kitano, Takeshi')\n),\nall_pairs AS (\n  SELECT d.director_id, a.actor_id,\n         COUNT(DISTINCT d.movie_id) AS film_count,\n         array_agg(DISTINCT d.movie_id) AS movie_ids\n  FROM dirs d\n  JOIN acts a ON d.movie_id = a.movie_id AND d.director_id != a.actor_id\n  JOIN title t ON t.id = d.movie_id\n  JOIN rated_movies rm ON rm.movie_id = t.id\n  JOIN dir_ids di ON di.id = d.director_id\n  WHERE t.production_year BETWEEN 1990 AND 2010 AND t.kind_id = 1\n  GROUP BY d.director_id, a.actor_id\n),\npair_genre_counts AS (\n  SELECT ap.director_id, ap.actor_id, ap.film_count,\n         COUNT(DISTINCT mi.info) AS distinct_genres\n  FROM all_pairs ap\n  JOIN movie_info mi ON mi.movie_id = ANY(ap.movie_ids)\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'genres')\n  GROUP BY ap.director_id, ap.actor_id, ap.film_count\n)\nSELECT\n  CASE WHEN film_count >= 4 THEN 'repeat (4+ films)'\n       WHEN film_count = 1 THEN 'one-off (1 film)'\n       ELSE '2-3 films' END AS pair_type,\n  COUNT(*) AS num_pairs,\n  ROUND(AVG(film_count), 2) AS avg_films,\n  ROUND(AVG(distinct_genres), 2) AS avg_distinct_genres,\n  ROUND(AVG(distinct_genres::numeric / film_count), 3) AS genre_diversity_ratio\nFROM pair_genre_counts\nGROUP BY CASE WHEN film_count >= 4 THEN 'repeat (4+ films)'\n              WHEN film_count = 1 THEN 'one-off (1 film)'\n              ELSE '2-3 films' END\nORDER BY avg_films DESC;",
