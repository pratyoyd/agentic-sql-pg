{
  "query_seq": 9,
  "sql": "WITH dirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id = (SELECT id FROM role_type WHERE role = 'director')\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id IN (SELECT id FROM role_type WHERE role IN ('actor', 'actress'))\n),\nrated_movies AS (\n  SELECT DISTINCT movie_id\n  FROM movie_info_idx\n  WHERE info_type_id = (SELECT id FROM info_type WHERE info = 'votes')\n    AND info::integer >= 500\n),\ntarget_pairs AS (\n  SELECT nd.id AS dir_id, na.id AS act_id, nd.name AS director, na.name AS actor\n  FROM name nd, name na\n  WHERE (nd.name, na.name) IN (\n    ('To, Johnnie', 'Lam, Suet'),\n    ('Marshall, Garry', 'Elizondo, Hector'),\n    ('Kitano, Takeshi', 'Terajima, Susumu'),\n    ('Rodriguez, Robert', 'Trejo, Danny')\n  )\n),\nshared_movies AS (\n  SELECT tp.director, tp.actor, d.movie_id\n  FROM target_pairs tp\n  JOIN dirs d ON d.director_id = tp.dir_id\n  JOIN acts a ON a.actor_id = tp.act_id AND a.movie_id = d.movie_id\n  JOIN title t ON t.id = d.movie_id\n  JOIN rated_movies rm ON rm.movie_id = t.id\n  WHERE t.production_year BETWEEN 1990 AND 2010 AND t.kind_id = 1\n),\nkeyword_stats AS (\n  SELECT sm.director, sm.actor,\n         k.keyword,\n         COUNT(DISTINCT sm.movie_id) AS kw_count\n  FROM shared_movies sm\n  JOIN movie_keyword mk ON mk.movie_id = sm.movie_id\n  JOIN keyword k ON k.id = mk.keyword_id\n  GROUP BY sm.director, sm.actor, k.keyword\n  HAVING COUNT(DISTINCT sm.movie_id) >= 2\n)\nSELECT director, actor, keyword, kw_count\nFROM keyword_stats\nORDER BY director, kw_count DESC, keyword\nLIMIT 60;",
