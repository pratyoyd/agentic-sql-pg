{
  "query_seq": 2,
  "sql": "WITH dirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id = (SELECT id FROM role_type WHERE role = 'director')\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  WHERE ci.role_id IN (SELECT id FROM role_type WHERE role IN ('actor', 'actress'))\n),\npairs AS (\n  SELECT d.director_id, a.actor_id,\n         COUNT(DISTINCT d.movie_id) AS film_count\n  FROM dirs d\n  JOIN acts a ON d.movie_id = a.movie_id AND d.director_id != a.actor_id\n  JOIN title t ON t.id = d.movie_id\n  JOIN movie_info mi ON mi.movie_id = t.id\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'countries')\n    AND mi.info IN ('USA', 'UK', 'France', 'Germany', 'Italy', 'Spain', 'Australia', 'Canada')\n  WHERE t.production_year BETWEEN 1990 AND 2010\n    AND t.kind_id = 1\n  GROUP BY d.director_id, a.actor_id\n  HAVING COUNT(DISTINCT d.movie_id) >= 5\n)\nSELECT\n  nd.name AS director,\n  na.name AS actor,\n  p.film_count\nFROM pairs p\nJOIN name nd ON nd.id = p.director_id\nJOIN name na ON na.id = p.actor_id\nORDER BY p.film_count DESC\nLIMIT 30;",
