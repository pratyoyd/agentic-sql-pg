{
  "query_seq": 7,
  "sql": "WITH director_role AS (SELECT id FROM role_type WHERE role = 'director'),\n     actor_role AS (SELECT id FROM role_type WHERE role IN ('actor', 'actress')),\n     rating_type AS (SELECT id FROM info_type WHERE info = 'rating'),\n     -- One-off pairs: same director, different actors appearing in exactly 1 film together\n     all_pairs AS (\n       SELECT ci_d.person_id AS director_id, ci_a.person_id AS actor_id,\n              t.id AS movie_id\n       FROM cast_info ci_d\n       JOIN cast_info ci_a ON ci_a.movie_id = ci_d.movie_id AND ci_a.person_id <> ci_d.person_id\n       JOIN title t ON t.id = ci_d.movie_id AND t.kind_id = 1 AND t.production_year BETWEEN 1990 AND 2010\n       JOIN movie_info_idx mii ON mii.movie_id = t.id AND mii.info_type_id = (SELECT id FROM rating_type)\n         AND mii.info::numeric >= 6.0\n       WHERE ci_d.role_id = (SELECT id FROM director_role)\n         AND ci_a.role_id IN (SELECT id FROM actor_role)\n     ),\n     pair_counts AS (\n       SELECT director_id, actor_id, COUNT(DISTINCT movie_id) AS film_count\n       FROM all_pairs\n       GROUP BY director_id, actor_id\n     ),\n     -- Classify: repeat (>=3 films) vs one-off (=1 film)\n     -- For top repeat directors only (Johnnie To, Wong Jing, Miike, de Oliveira)\n     top_directors AS (\n       SELECT id FROM name WHERE name IN ('To, Johnnie', 'Wong, Jing', 'Miike, Takashi', 'de Oliveira, Manoel')\n     )\nSELECT\n  CASE WHEN pc.film_count >= 3 THEN 'repeat (3+)' ELSE 'one-off (1)' END AS collab_type,\n  COUNT(DISTINCT (pc.director_id, pc.actor_id)) AS pair_count,\n  ROUND(AVG(pc.film_count), 2) AS avg_films_together,\n  COUNT(DISTINCT ap.movie_id) AS total_films\nFROM pair_counts pc\nJOIN all_pairs ap ON ap.director_id = pc.director_id AND ap.actor_id = pc.actor_id\nWHERE pc.director_id IN (SELECT id FROM top_directors)\n  AND pc.film_count IN (1) OR pc.film_count >= 3\nGROUP BY collab_type\nORDER BY collab_type;",
