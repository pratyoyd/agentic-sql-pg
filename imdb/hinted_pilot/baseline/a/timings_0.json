{
  "query_seq": 0,
  "sql": "WITH director_role AS (\n  SELECT id FROM role_type WHERE role = 'director'\n),\nactor_roles AS (\n  SELECT id FROM role_type WHERE role IN ('actor', 'actress')\n),\nmovies AS (\n  SELECT id FROM title\n  WHERE kind_id = 1  -- movies only\n    AND production_year BETWEEN 1990 AND 2010\n),\ndirectors AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  JOIN director_role dr ON ci.role_id = dr.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\nactors AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  JOIN actor_roles ar ON ci.role_id = ar.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n)\nSELECT\n  d.director_id,\n  a.actor_id,\n  nd.name AS director_name,\n  na.name AS actor_name,\n  COUNT(*) AS film_count\nFROM directors d\nJOIN actors a ON d.movie_id = a.movie_id\nJOIN name nd ON d.director_id = nd.id\nJOIN name na ON a.actor_id = na.id\nWHERE d.director_id <> a.actor_id\nGROUP BY d.director_id, a.actor_id, nd.name, na.name\nHAVING COUNT(*) >= 3\nORDER BY film_count DESC\nLIMIT 30;",
