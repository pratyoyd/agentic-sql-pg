{
  "query_seq": 4,
  "sql": "WITH director_role AS (SELECT id FROM role_type WHERE role = 'director'),\nactor_roles AS (SELECT id FROM role_type WHERE role IN ('actor','actress')),\nmovies AS (SELECT id FROM title WHERE kind_id = 1 AND production_year BETWEEN 1990 AND 2010),\ndirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci JOIN director_role dr ON ci.role_id = dr.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci JOIN actor_roles ar ON ci.role_id = ar.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\npair_counts AS (\n  SELECT d.director_id, a.actor_id, COUNT(*) AS film_count\n  FROM dirs d JOIN acts a ON d.movie_id = a.movie_id\n  WHERE d.director_id <> a.actor_id\n  GROUP BY d.director_id, a.actor_id\n),\npair_genres AS (\n  SELECT pc.director_id, pc.actor_id, pc.film_count,\n         mi.info AS genre,\n         COUNT(*) AS genre_films\n  FROM pair_counts pc\n  JOIN dirs d ON d.director_id = pc.director_id\n  JOIN acts a ON a.actor_id = pc.actor_id AND a.movie_id = d.movie_id\n  JOIN movie_info mi ON mi.movie_id = d.movie_id\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'genres')\n  WHERE pc.film_count BETWEEN 1 AND 30\n  GROUP BY pc.director_id, pc.actor_id, pc.film_count, mi.info\n),\ngenre_hhi AS (\n  SELECT director_id, actor_id, film_count,\n         SUM((genre_films::float / film_count)^2) AS hhi  -- 1=pure, ~0=diverse\n  FROM pair_genres\n  GROUP BY director_id, actor_id, film_count\n),\nbuckets AS (\n  SELECT\n    CASE WHEN film_count = 1 THEN '1_oneoff'\n         WHEN film_count = 2 THEN '2_twooff'\n         WHEN film_count BETWEEN 3 AND 5 THEN '3-5_repeat'\n         WHEN film_count BETWEEN 6 AND 10 THEN '6-10_frequent'\n         ELSE '11+_prolific'\n    END AS bucket,\n    AVG(hhi) AS avg_hhi,\n    COUNT(*) AS pair_count\n  FROM genre_hhi\n  GROUP BY bucket\n)\nSELECT bucket, pair_count, ROUND(avg_hhi::numeric, 3) AS avg_genre_concentration\nFROM buckets\nORDER BY bucket;",
