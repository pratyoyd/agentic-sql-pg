{
  "query_seq": 3,
  "sql": "WITH top_pairs AS (\n  SELECT * FROM (VALUES\n    (433237, 179356),\n    (1560859, 864559),\n    (1189526, 1499363),\n    (391018, 816575),\n    (1697339, 2686282)\n  ) AS pairs(director_id, actor_id)\n),\npair_movies AS (\n  SELECT tp.director_id, tp.actor_id, d.movie_id\n  FROM top_pairs tp\n  JOIN cast_info d ON d.person_id = tp.director_id\n  JOIN cast_info a ON a.person_id = tp.actor_id AND a.movie_id = d.movie_id\n  JOIN title t ON t.id = d.movie_id\n  WHERE t.kind_id = 1\n    AND t.production_year BETWEEN 1990 AND 2010\n    AND d.role_id = (SELECT id FROM role_type WHERE role = 'director')\n    AND a.role_id IN (SELECT id FROM role_type WHERE role IN ('actor','actress'))\n)\nSELECT\n  nd.name AS director_name,\n  na.name AS actor_name,\n  k.keyword,\n  COUNT(*) AS films_with_keyword\nFROM top_pairs tp\nJOIN pair_movies pm ON pm.director_id = tp.director_id AND pm.actor_id = tp.actor_id\nJOIN movie_keyword mk ON mk.movie_id = pm.movie_id\nJOIN keyword k ON k.id = mk.keyword_id\nJOIN name nd ON nd.id = tp.director_id\nJOIN name na ON na.id = tp.actor_id\nGROUP BY tp.director_id, tp.actor_id, nd.name, na.name, k.keyword\nHAVING COUNT(*) >= 4\nORDER BY tp.director_id, films_with_keyword DESC\nLIMIT 50;",
