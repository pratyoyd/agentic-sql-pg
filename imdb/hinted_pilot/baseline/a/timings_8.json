{
  "query_seq": 8,
  "sql": "WITH director_role AS (SELECT id FROM role_type WHERE role = 'director'),\nactor_roles AS (SELECT id FROM role_type WHERE role IN ('actor','actress')),\nmovies AS (SELECT id FROM title WHERE kind_id = 1 AND production_year BETWEEN 1990 AND 2010),\ndirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci JOIN director_role dr ON ci.role_id = dr.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci JOIN actor_roles ar ON ci.role_id = ar.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\npair_counts AS (\n  SELECT d.director_id, a.actor_id, COUNT(*) AS film_count,\n         array_agg(DISTINCT d.movie_id) AS movie_ids\n  FROM dirs d JOIN acts a ON d.movie_id = a.movie_id\n  WHERE d.director_id <> a.actor_id\n  GROUP BY d.director_id, a.actor_id\n  HAVING COUNT(*) >= 10\n),\npair_country AS (\n  SELECT pc.director_id, pc.actor_id, pc.film_count,\n         mi.info AS country,\n         COUNT(*) AS country_films\n  FROM pair_counts pc\n  JOIN LATERAL (SELECT unnest(pc.movie_ids) AS movie_id) m ON true\n  JOIN movie_info mi ON mi.movie_id = m.movie_id\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'countries')\n  GROUP BY pc.director_id, pc.actor_id, pc.film_count, mi.info\n),\ntop_country_per_pair AS (\n  SELECT director_id, actor_id, film_count,\n         country AS dominant_country,\n         country_films,\n         RANK() OVER (PARTITION BY director_id, actor_id ORDER BY country_films DESC) AS rnk\n  FROM pair_country\n),\ntop_pairs_with_country AS (\n  SELECT tc.director_id, tc.actor_id, tc.film_count, tc.dominant_country,\n         nd.name AS director_name, na.name AS actor_name\n  FROM top_country_per_pair tc\n  JOIN name nd ON nd.id = tc.director_id\n  JOIN name na ON na.id = tc.actor_id\n  WHERE tc.rnk = 1\n)\nSELECT dominant_country, COUNT(*) AS pair_count, ROUND(AVG(film_count),1) AS avg_films\nFROM top_pairs_with_country\nGROUP BY dominant_country\nORDER BY pair_count DESC\nLIMIT 20;",
