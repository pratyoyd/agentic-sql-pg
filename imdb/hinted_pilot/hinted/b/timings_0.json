{
  "query_seq": 0,
  "sql": "WITH director_roles AS (\n  SELECT id AS role_id FROM role_type WHERE role = 'director'\n),\nactor_roles AS (\n  SELECT id AS role_id FROM role_type WHERE role IN ('actor', 'actress')\n),\ndirectors AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  JOIN director_roles dr ON ci.role_id = dr.role_id\n),\nactors AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  JOIN actor_roles ar ON ci.role_id = ar.role_id\n),\ncollab AS (\n  SELECT d.director_id, a.actor_id, COUNT(*) AS film_count\n  FROM directors d\n  JOIN actors a ON d.movie_id = a.movie_id\n  JOIN title t ON t.id = d.movie_id\n  WHERE t.production_year BETWEEN 1990 AND 2010\n    AND t.kind_id = 1  -- movies only\n  GROUP BY d.director_id, a.actor_id\n  HAVING COUNT(*) >= 3\n)\nSELECT\n  nd.name AS director_name,\n  na.name AS actor_name,\n  c.film_count\nFROM collab c\nJOIN name nd ON nd.id = c.director_id\nJOIN name na ON na.id = c.actor_id\nORDER BY c.film_count DESC\nLIMIT 30;",
  "hint_block": "",
  "hinted_sql": "WITH director_roles AS (\n  SELECT id AS role_id FROM role_type WHERE role = 'director'\n),\nactor_roles AS (\n  SELECT id AS role_id FROM role_type WHERE role IN ('actor', 'actress')\n),\ndirectors AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci\n  JOIN director_roles dr ON ci.role_id = dr.role_id\n),\nactors AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci\n  JOIN actor_roles ar ON ci.role_id = ar.role_id\n),\ncollab AS (\n  SELECT d.director_id, a.actor_id, COUNT(*) AS film_count\n  FROM directors d\n  JOIN actors a ON d.movie_id = a.movie_id\n  JOIN title t ON t.id = d.movie_id\n  WHERE t.production_year BETWEEN 1990 AND 2010\n    AND t.kind_id = 1  -- movies only\n  GROUP BY d.director_id, a.actor_id\n  HAVING COUNT(*) >= 3\n)\nSELECT\n  nd.name AS director_name,\n  na.name AS actor_name,\n  c.film_count\nFROM collab c\nJOIN name nd ON nd.id = c.director_id\nJOIN name na ON na.id = c.actor_id\nORDER BY c.film_count DESC\nLIMIT 30;",
