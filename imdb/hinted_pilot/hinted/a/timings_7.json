{
  "query_seq": 7,
  "sql": "WITH director_role AS (SELECT id FROM role_type WHERE role = 'director'),\nactor_roles AS (SELECT id FROM role_type WHERE role IN ('actor','actress')),\nmovies AS (SELECT id FROM title WHERE kind_id = 1 AND production_year BETWEEN 1990 AND 2010),\ndirs AS (\n  SELECT ci.person_id AS director_id, ci.movie_id\n  FROM cast_info ci JOIN director_role dr ON ci.role_id = dr.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\nacts AS (\n  SELECT ci.person_id AS actor_id, ci.movie_id\n  FROM cast_info ci JOIN actor_roles ar ON ci.role_id = ar.id\n  WHERE ci.movie_id IN (SELECT id FROM movies)\n),\npair_films AS (\n  SELECT d.director_id, a.actor_id, d.movie_id,\n         COUNT(*) OVER (PARTITION BY d.director_id, a.actor_id) AS film_count\n  FROM dirs d JOIN acts a ON d.movie_id = a.movie_id\n  WHERE d.director_id <> a.actor_id\n),\npair_genre_counts AS (\n  SELECT pf.director_id, pf.actor_id, pf.film_count,\n         mi.info AS genre,\n         COUNT(DISTINCT pf.movie_id) AS genre_films\n  FROM pair_films pf\n  JOIN movie_info mi ON mi.movie_id = pf.movie_id\n    AND mi.info_type_id = (SELECT id FROM info_type WHERE info = 'genres')\n  WHERE pf.film_count >= 1\n  GROUP BY pf.director_id, pf.actor_id, pf.film_count, mi.info\n),\ntop_genre_per_pair AS (\n  SELECT director_id, actor_id, film_count,\n         MAX(genre_films) AS top_genre_films\n  FROM pair_genre_counts\n  GROUP BY director_id, actor_id, film_count\n),\nbucketed AS (\n  SELECT\n    CASE WHEN film_count = 1 THEN '1_oneoff'\n         WHEN film_count = 2 THEN '2_twofilm'\n         WHEN film_count BETWEEN 3 AND 5 THEN '3-5_repeat'\n         WHEN film_count BETWEEN 6 AND 10 THEN '6-10_frequent'\n         WHEN film_count BETWEEN 11 AND 20 THEN '11-20_prolific'\n         ELSE '21+_extreme'\n    END AS bucket,\n    COUNT(*) AS pair_count,\n    AVG(top_genre_films::float / film_count) AS avg_dominant_genre_fraction\n  FROM top_genre_per_pair\n  GROUP BY bucket\n)\nSELECT bucket, pair_count, ROUND(avg_dominant_genre_fraction::numeric, 3) AS avg_dominant_genre_share\nFROM bucketed\nORDER BY bucket;",
  "hint_block": "/*+ Rows(ci ci_1 role_type role_type_1 #2436083) Rows(ci_1 role_type_1 #2229373) Rows(ci role_type #259580) */",
