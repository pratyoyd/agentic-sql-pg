avg_dominant_genre_fraction\n  FROM top_genre_per_pair\n  GROUP BY bucket\n)\nSELECT bucket, pair_count, ROUND(avg_dominant_genre_fraction::numeric, 3) AS avg_dominant_genre_share\nFROM bucketed\nORDER BY bucket;",
